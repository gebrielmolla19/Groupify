# Spotify API Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional: Additional Spotify apps for multi-app workaround (5 users per app in dev mode)
# Create extra apps in the Spotify Developer Dashboard, add the same redirect URI to each,
# and add 5 users to each app's allowlist. Share /login?app=1 with users 6-10, /login?app=2 with users 11-15.
# SPOTIFY_CLIENT_ID_1=your_second_app_client_id
# SPOTIFY_CLIENT_SECRET_1=your_second_app_client_secret
# SPOTIFY_CLIENT_ID_2=your_third_app_client_id
# SPOTIFY_CLIENT_SECRET_2=your_third_app_client_secret

# Spotify OAuth Redirect URI
# Must match the redirect URI registered in your Spotify app settings
# Local dev: http://localhost:5001/api/v1/auth/callback
# Production: https://api.yourdomain.com/api/v1/auth/callback
SPOTIFY_REDIRECT_URI=http://localhost:5001/api/v1/auth/callback

# MongoDB Connection String
# Local: mongodb://localhost:27017/groupify
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/groupify
MONGO_URI=mongodb://localhost:27017/groupify

# JWT Secret Key
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# Server Port
PORT=5001

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS and OAuth redirects)
# Local: http://localhost:3000
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:3000