# Groupify Frontend — example environment variables.
# Copy to `.env` and adjust as needed for local development.

# Base URL of the Groupify backend API (no trailing slash).
# Defaults to http://127.0.0.1:5001/api/v1 if unset.
VITE_API_BASE_URL=http://127.0.0.1:5001/api/v1

# Socket.io connection URL. Optional — derived from VITE_API_BASE_URL
# (with /api/v1 stripped) if unset. Override only if the websocket
# endpoint lives on a different host or port from the REST API.
# VITE_SOCKET_URL=http://127.0.0.1:5001
